NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=logs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Supabase PostgreSQL
# Find in Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — SDK (needed for Storage, Realtime, or direct client queries)
# Find in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key

# Auth.js — optional until OAuth is configured
# AUTH_SECRET: generate with: openssl rand -base64 32
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: from Google Cloud Console OAuth credentials
# AUTH_SECRET=your-auth-secret
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
